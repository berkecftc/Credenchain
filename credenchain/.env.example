# ============================================
# CredenChain Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---- Database (Prisma v7) ----
# PrismaClient constructor ve prisma.config.ts tarafından kullanılır
DATABASE_URL="postgresql://user:password@localhost:5432/credenchain?schema=public"

# ---- Stellar / Soroban Blockchain ----
SOROBAN_RPC_URL="https://soroban-testnet.stellar.org"
SOROBAN_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
SOROBAN_CONTRACT_ID="your-deployed-contract-id-here"
STELLAR_SECRET_KEY="your-stellar-secret-key-here"

# ---- Application ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="CredenChain"
